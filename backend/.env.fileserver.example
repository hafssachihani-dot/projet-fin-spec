AGENTIC_WEBHOOK_URL=https://stg-agentic.abafusion.ai/api/v1/webhook/your-workflow-id

# Ask the platform team/friend for these two values.
# The upload API must return a JSON field like file_path, server_file_path, path, url, id, or data.file_path.
AGENTIC_FILE_SERVER_ENABLED=true
AGENTIC_FILE_UPLOAD_URL=https://stg-agentic.abafusion.ai/api/v2/files
AGENTIC_API_KEY=sk-your-agentic-api-key
AGENTIC_FILE_UPLOAD_TOKEN=
AGENTIC_FILE_UPLOAD_FIELD=file

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_legacy_service_role_jwt

GOOGLE_API_KEY=optional_for_this_poc
